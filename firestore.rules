rules_version = '2';

// ─────────────────────────────────────────────────────────────
// おうちの買い物 ・ Firestore セキュリティルール
//
// 方針（買い物リストは機密性が低いので、シンプルさを優先）：
//   ・匿名ログイン済み（request.auth != null）の利用者のみ読み書き可
//   ・家族データは families/{家族コード}/... の下に入る
//   ・家族コードを知らない他人は、そのコードのデータに辿り着けない
//
// 注意：このルールは「コードを知っていれば読める」方式です。
//       家族コードは推測されにくい言葉にし、家族以外に共有しないでください。
//       もっと厳密にしたい場合は、家族ごとにメンバーuidを登録して
//       所属チェックする方式に拡張できます（必要になったら相談を）。
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    match /families/{familyCode}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // 上記以外はすべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
